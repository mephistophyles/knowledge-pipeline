# Copy to .env for local runs. Only needed once real ingestors / S3 / LLM stages land.
# For steps 1–2 (paste + annotate + state machine) nothing here is required.

# Override the config file location (default: config/pipeline.yaml)
# PIPELINE_CONFIG=config/pipeline.yaml

# S3 blob store (only when storage.blobstore=s3). Prefer IAM instance profiles on EC2.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
