# Copy to .env for local runs. Loaded automatically by the CLI (python-dotenv).
# For steps 1–2 (paste + annotate + state machine) nothing here is required.

# Override the config file location (default: config/pipeline.yaml)
# PIPELINE_CONFIG=config/pipeline.yaml

# LLM providers (build step 5). Only the provider(s) your `models:` map references
# are needed. Keys map to `api_key_env` in config/pipeline.yaml's `providers:`.
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# Ollama is keyless (local) — nothing to set; just have it running.

# Email ingestion (build step 3) — a Gmail app password (requires 2FA on the account).
# The ingestor is read-only (never marks mail seen). Host is set in config/pipeline.yaml.
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your-16-char-app-password

# S3 blob store (only when storage.blobstore=s3). Prefer IAM instance profiles on EC2.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
