# Runtime data — NOT in the repo (per plan §2). Raw blobs, DB, intermediates.
/data/
# The vault is a separate private git repo mounted alongside.
/vault/
# Eval/backlog data — real newsletter text, subscription list, extracted claims. Stays
# LOCAL: public repo + third-party content + personal data. Prompts live in config/prompts/.
/evals/

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Env / secrets
.env

# Terraform — state can contain secrets; tfvars is per-environment. Never commit.
# (.terraform.lock.hcl IS committed — it pins provider versions.)
infra/.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
*.auto.tfvars

# OS
.DS_Store
